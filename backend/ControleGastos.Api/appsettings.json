{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=controle_gastos.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Issuer": "ControleGastos",
    "Audience": "ControleGastosApp",
    "Secret": "CHANGE-ME-IN-PRODUCTION-MIN-32-CHARS!!",
    "ExpirationMinutes": 480
  },
  "Auth": {
    "Username": "admin",
    "Password": "admin"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
